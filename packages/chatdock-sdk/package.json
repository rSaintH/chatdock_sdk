{
  "name": "@rscheln/chatdock-sdk",
  "version": "0.1.3",
  "description": "All-in-one SDK for adding tool-calling chatbots to React, Next.js, and Supabase applications.",
  "keywords": [
    "chatbot",
    "ai",
    "ai-sdk",
    "react",
    "nextjs",
    "supabase",
    "tools",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rSaintH/chatdock-sdk.git",
    "directory": "packages/chatdock-sdk"
  },
  "bugs": {
    "url": "https://github.com/rSaintH/chatdock-sdk/issues"
  },
  "homepage": "https://github.com/rSaintH/chatdock-sdk#readme",
  "type": "module",
  "sideEffects": [
    "./src/styles.css"
  ],
  "bin": {
    "chatdock-sdk": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./supabase": {
      "types": "./dist/supabase.d.ts",
      "import": "./dist/supabase.js"
    },
    "./styles.css": {
      "default": "./src/styles.css"
    },
    "./supabase/schema.sql": "./src/supabase/schema.sql"
  },
  "files": [
    "dist",
    "src/styles.css",
    "src/supabase/schema.sql"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@rscheln/cli": "workspace:^",
    "@rscheln/next": "workspace:^",
    "@rscheln/react": "workspace:^",
    "@rscheln/server": "workspace:^",
    "@rscheln/supabase": "workspace:^"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2",
    "ai": "^6.0.0",
    "next": ">=15",
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
