{
  "name": "@rsainth/chatdock-sdk",
  "version": "0.1.6",
  "description": "All-in-one SDK for adding tool-calling chatbots to React, Next.js, and Supabase applications.",
  "keywords": [
    "chatbot",
    "ai",
    "ai-sdk",
    "react",
    "nextjs",
    "supabase",
    "tools",
    "streaming"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsainth/chatdock_sdk.git",
    "directory": "packages/chatdock-sdk"
  },
  "bugs": {
    "url": "https://github.com/rsainth/chatdock_sdk/issues"
  },
  "homepage": "https://github.com/rsainth/chatdock_sdk#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "./src/styles.css"
  ],
  "bin": {
    "chatdock-sdk": "./dist/cli.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./supabase": {
      "types": "./dist/supabase.d.ts",
      "import": "./dist/supabase.js"
    },
    "./styles.css": {
      "default": "./src/styles.css"
    },
    "./supabase/schema.sql": "./src/supabase/schema.sql"
  },
  "files": [
    "dist",
    "scripts",
    "src/styles.css",
    "src/supabase/schema.sql"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/react.ts src/server.ts src/next.ts src/supabase.ts src/cli.ts --format esm --dts --sourcemap --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "smoke:imports": "node ./scripts/smoke-imports.mjs"
  },
  "dependencies": {
    "@rsainth/cli": "workspace:^",
    "@rsainth/next": "workspace:^",
    "@rsainth/react": "workspace:^",
    "@rsainth/server": "workspace:^",
    "@rsainth/supabase": "workspace:^"
  },
  "peerDependencies": {
    "@supabase/supabase-js": ">=2",
    "ai": "^6.0.0",
    "next": ">=15",
    "react": ">=18.2.0 || >=19.0.0",
    "react-dom": ">=18.2.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "@supabase/supabase-js": {
      "optional": true
    },
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
