{
  "name": "@rscheln/server",
  "version": "0.1.2",
  "description": "Framework-agnostic backend core for Chatdock SDK.",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "exports": {
