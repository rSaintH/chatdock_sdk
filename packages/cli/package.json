{
  "name": "@rsainth/cli",
  "version": "0.1.2",
  "description": "CLI for initializing and syncing Chatdock SDK projects.",
  "type": "module",
  "bin": {
    "chatdock-sdk": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0"
  },
  "engines": {
    "node": ">=20"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
